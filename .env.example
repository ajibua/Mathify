SECRET_KEY=django-insecure-replace-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
GEMINI_API_KEY=gemini-api-key
GOOGLE_OAUTH_CLIENT_ID=client-id
GOOGLE_OAUTH_CLIENT_SECRET=client-secret
MICROSOFT_OAUTH_CLIENT_ID=client-id
MICROSOFT_OAUTH_CLIENT_SECRET=client-secret
OAUTH_REDIRECT_BASE_URL=base-url

# Email Configurations (SMTP/Console)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@mathify.edu